{
  "manifest_version": 3,
  "name": "Word Replacer",
  "version": "0.1.0",
  "description": "Replaces specified words on web pages",
  "permissions": ["storage"],
  "action": {
    "default_title": "Word Replacer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
